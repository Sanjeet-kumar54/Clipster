# ClipSkari Frontend Environment Variables
# Copy this file to `.env.local` and fill in real values.

# Supabase (from Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...

# FastAPI backend URL
# In production: https://your-api.onrender.com (or Railway/Fly/etc.)
# In dev: empty string to use Vite proxy (see vite.config.ts)
VITE_API_BASE_URL=
