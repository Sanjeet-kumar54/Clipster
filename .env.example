# ============================================================
# ClipSkari Root Environment Variables
# ============================================================
# Copy to `.env` and fill in real values. Each subproject
# (frontend/, backend/) has its own .env.example too.
# ============================================================

# ── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Supabase (https://app.supabase.com → Project Settings → API) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJI...   # Public, frontend-safe
SUPABASE_SERVICE_KEY=eyJhbGciOiJI... # SERVER ONLY — never expose to frontend!
SUPABASE_JWT_SECRET=your-jwt-secret   # Project Settings → API → JWT Secret
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# ── Modal (https://modal.com → Settings → API Tokens) ──
MODAL_APP_NAME=clipskari-reframer
MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxx
MODAL_DEPLOYED=false   # true after `modal deploy`

# ── Groq LLM (https://console.groq.com → API Keys) ──
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Pexels (optional — https://www.pexels.com/api) ──
PEXELS_API_KEY=

# ── Frontend (Vite reads VITE_* vars at build time) ──
# Empty = use Vite proxy to localhost:8000 in dev
VITE_API_BASE_URL=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Job scheduler ───────────────────────────────────────────
JOB_POLL_INTERVAL_SEC=5
JOB_MAX_RUNTIME_SEC=3600
