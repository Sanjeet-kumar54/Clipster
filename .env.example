# ============================================================
# Clipster Root Environment Variables
# ============================================================
# Copy to `.env` and fill in real values. Each subproject
# (frontend/, backend/) has its own .env.example too.
# ============================================================

# ── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Supabase (https://app.supabase.com → Project Settings → API) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key  # Public, frontend-safe
SUPABASE_SERVICE_KEY=your_supabase_service_key # SERVER ONLY — never expose to frontend!
SUPABASE_JWT_SECRET=your_supabase_jwt_secret   # Project Settings → API → JWT Secret
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Modal (https://modal.com → Settings → API Tokens) ──
MODAL_APP_NAME=Clipster
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret
MODAL_DEPLOYED=true   # true after `modal deploy`

# ── Groq LLM (https://console.groq.com → API Keys) ──
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Pexels (optional — https://www.pexels.com/api) ──
PEXELS_API_KEY=your_pexels_api_key

# ── Frontend (Vite reads VITE_* vars at build time) ──
# Empty = use Vite proxy to localhost:8000 in dev
VITE_API_BASE_URL=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Job scheduler ───────────────────────────────────────────
JOB_POLL_INTERVAL_SEC=5
JOB_MAX_RUNTIME_SEC=3600
