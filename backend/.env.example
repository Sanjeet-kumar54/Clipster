# ClipSkari Backend Environment Variables
# Copy this file to `.env` and fill in real values.

# ── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase ────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_KEY=eyJhbG...   # SERVER ONLY — never expose to frontend!
SUPABASE_JWT_SECRET=your-jwt-secret  # From Project Settings → API → JWT Secret

# ── Modal ───────────────────────────────────────────────────
# From: modal.com → Settings → API Tokens
MODAL_APP_NAME=clipskari-reframer
MODAL_TOKEN_ID=ak-xxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxx
MODAL_DEPLOYED=true   # Set to false for local dev without Modal

# ── Job scheduling ──────────────────────────────────────────
JOB_POLL_INTERVAL_SEC=5
JOB_MAX_RUNTIME_SEC=3600
JOB_MAX_CONCURRENT_PER_USER=1

# ── Storage ─────────────────────────────────────────────────
STORAGE_BUCKET_CLIPS=clips
STORAGE_BUCKET_QC=qc-grids
SIGNED_URL_EXPIRY_SEC=604800

# ── LLM (Groq) ──────────────────────────────────────────────
# From: console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Pexels (optional, for B-roll) ───────────────────────────
PEXELS_API_KEY=
